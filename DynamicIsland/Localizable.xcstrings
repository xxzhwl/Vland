          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Two-finger swipe up on notch to close, two-finger swipe down on notch to open when **Open notch on hover** option is disabled"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Two-finger swipe up on notch to close, two-finger swipe down on notch to open when **Open notch on hover** option is disabled"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Glisser deux doigts vers le haut sur l'encoche pour la fermer, glisser deux doigts vers le bas sur l'encoche pour l'ouvrir lorsque l'option **Ouvrir l'encoche au survolant** est désactivée"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "needs_review",

    "Panel mode shows clipboard in a floating window near the notch.": {
      "comment": "A description of the \"Panel\" clipboard display mode.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "패널 모드는 노치 근처의 플로팅 윈도우에 클립보드를 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {

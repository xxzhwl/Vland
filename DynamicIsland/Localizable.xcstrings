    "Display and create notes from macOS Notes app instead of built-in storage.": {},
    "Displays a HUD notification when Bluetooth audio devices (headphones, AirPods, speakers) connect, showing device name and battery level.": {
      "comment": "A footer for the \"Bluetooth Audio Devices\" section in the HUD settings.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche une notification sur l’ATH lorsque des appareils audio Bluetooth (Écouteurs, AirPods, enceintes) se connectent, et affiche le nom et la charge de la batterie de celui-ci."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Bluetooth 오디오 기기(헤드폰, AirPods, 스피커)가 연결되면 기기 이름과 배터리 잔량을 보여주는 HUD 알림을 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exibe uma notificação HUD quando os dispositivos de áudio Bluetooth (fones de ouvido, AirPods, alto-falantes) se conectam, mostrando o nome do dispositivo e o nível da bateria."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Стиль дисплея"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "蓝牙音频设备（耳机、AirPods、扬声器）连接时显示 HUD 通知，包含设备名称和电池电量。"
          }
        }
      }
    },
    "Displays play/pause and skip buttons beside the notch while music is active. Disabled by default.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "음악이 재생 중일 때 노치 옆에 재생/일시 정지 및 건너뛰기 버튼을 표시합니다. 이 기능은 기본적으로 비활성화되어 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Exibe os botões de reprodução/pausa e pular ao lado do notch enquanto a música está ativa. Desativado por padrão."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отображает кнопки \"Воспроизведение/Пауза\" и \"Вперед\" рядом с вырезом при активной музыке. Отключено по умолчанию."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "音乐播放时在刘海旁边显示播放/暂停和跳过按钮。默认禁用。"
          }
        }
      }
    },
    "Displays the current Focus state above the weather capsule whenever Focus detection is enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "집중 모드 감지가 활성화된 경우 날씨 캡슐 위에 현재 집중 모드 상태를 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Exibe o estado atual do Foco acima da cápsula climática sempre que a detecção de Foco está ativada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает текущее Фокусирование над виджетом погоды, если включено отслеживание Фокусирования."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用专注检测时，在天气胶囊上方显示当前专注状态。"
          }
        }
      }
    },
    "Displays your next upcoming calendar event above or below the weather capsule. Calendar selection here is independent from the Dynamic Island calendar filter.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "날씨 캡슐의 위 또는 아래에 예정된 다음 일정을 표시합니다. 여기서 선택한 캘린더는 Dynamic Island의 캘린더 필터와 별개로 적용됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Показывает следующее событие календаря над или под виджетом погоды. Выбор календаря не зависит от фильтров Dynamic Island."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在天气胶囊上方或下方显示下一个即将到来的日历事件。此处的日历选择独立于灵动岛日历过滤器。"
          }
        }
      }
    },

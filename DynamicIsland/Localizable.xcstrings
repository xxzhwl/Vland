    },
    "Controls how often system metrics refresh while monitoring is active.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모니터링이 활성화된 동안 시스템 측정값이 새로고침되는 빈도를 조절합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla com que frequência as métricas do sistema são atualizadas enquanto o monitoramento está ativo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляет частотой обновления системных метрик при активном мониторинге."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制监控激活时系统指标的刷新频率。"
          }
        }
      }
    },
    "Controls the lock screen reminder chip and its positioning.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠금 화면 리마인더 칩과 그 위치를 제어합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляет плашкой напоминаний на экране блокировки и ее позицией."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制锁屏提醒标签及其位置。"
          }
        }
      }
    },
    "Controls the optional timer widget that floats above the media panel, including its classic, frosted, or liquid glass surface independent of the global material setting.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "미디어 패널 위에 떠 있는 선택적 타이머 위젯을 제어합니다. 여기에는 전체 Material 설정과는 별개로 적용되는 클래식, 프로스티드 또는 리퀴드 글래스 스타일이 포함됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla o widget de temporizador opcional que flutua acima do painel de mídia, incluindo sua superfície de vidro clássico, fosco ou líquido, independentemente da configuração global do material."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляет областью напоминаний на экране блокировки и её расположением."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制浮动在媒体面板上方的可选计时器小组件，包括其经典、磨砂或液态玻璃表面（独立于全局材质设置）。"
          }
        }
      }
    },
    "Controls whether Dynamic Island mirrors lock/unlock events with its own live activity and audible chimes.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Dynamic Island가 자체 실시간 현황 및 효과음과 함께 잠금/잠금 해제 이벤트를 연동할지 여부를 제어합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla se a Dynamic Island espelha eventos de bloqueio/desbloqueio com sua própria atividade ao vivo e sinos audíveis."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляет тем, дублирует ли Dynamic Island системные события блокировки/разблокировки своими Live Activity и звуками."
          }
        },
        "zh-Hans": {
          "stringUnit": {

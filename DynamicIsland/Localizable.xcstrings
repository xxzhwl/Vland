    "Configure countdown style and lock screen widgets in the Calendar tab.": {
      "comment": "A footer for the \"Enable reminder live activity\" toggle in the Live Activities settings.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캘린더 탭에서 카운트다운 스타일과 잠금 화면 위젯을 설정하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure o estilo de contagem regressiva e os widgets da tela de bloqueio na guia Calendário."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте стиль обратного отсчета и виджеты на вкладке Calendar."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在日历标签页中配置倒计时样式和锁屏小组件。"
          }
        }
      }
    },
    "Configure hooks in Settings → AI Agents": {},
    "Configure how the timer looks inside the closed notch. Progress can render as a ring around the icon or as horizontal bars.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노치가 닫혔을 때의 타이머 모양을 설정하세요. 진행 상황은 아이콘 주변의 고리 또는 가로 막대 형태로 표시될 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure como o temporizador fica dentro do notch fechado. O progresso pode ser renderizado como um anel ao redor do ícone ou como barras horizontais."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте внешний вид таймера в закрытом вырезе."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "配置计时器在关闭的刘海中的外观。进度可以显示为图标周围的圆环或水平条。"
          }
        }
      }
    },
    "Configure lock screen materials from the Appearance tab. Custom Liquid unlocks variant sliders for both widgets whenever Liquid Glass is selected.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면 표시 탭에서 잠금 화면 Material을 설정하세요. '리퀴드 글래스'를 선택하면 두 위젯 모두에서 '사용자 지정 리퀴드' 스타일 슬라이더를 사용할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure os materiais da tela de bloqueio na aba Aparência. O Custom Liquid desbloqueia controles deslizantes variantes para ambos os widgets sempre que o Liquid Glass é selecionado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте материалы экрана блокировки на вкладке Appearance."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在外观标签页中配置锁屏材质。选择液态玻璃时，自定义液态将解锁两个小组件的变体滑块。"
          }
        }
      }
    },
    "Configure presets in Settings": {
      "comment": "A message displayed when there are no presets configured. It encourages the user to configure presets in the app settings.",
      "isCommentAutoGenerated": true,
      "localizations": {

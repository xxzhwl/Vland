          }
        }
      }
    },
    "Choose animation to display when Vland is idle. Tap to select, hold to delete custom animations.": {
      "comment": "A footer label under the section that lists their idle animations.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie die Animation aus, die angezeigt werden soll, wenn Vland im Leerlauf ist. Tippen Sie zum Auswählen und halten Sie zum Löschen benutzerdefinierter Animationen gedrückt."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisir une animation à afficher lorsque la Vland est inactive. Touchez pour sélectionner, maintenez pour supprimer."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Vland이 유휴 상태일 때 표시할 애니메이션을 선택하세요. 탭하여 선택하고, 길게 눌러 사용자 지정 애니메이션을 삭제할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha a animação para exibir quando o Atol estiver ocioso. Toque para selecionar, segure para excluir animações personalizadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите анимацию для режима ожидания. Нажмите для выбора, удерживайте для удаления."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择 Vland 空闲时显示的动画。点击选择，长按删除自定义动画。"
          }
        }
      }
    },
    "Choose directly on which side of the screen the vertical bar appears.": {
      "localizations": {
        "ko": {
          "stringUnit": {

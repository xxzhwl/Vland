    "Mirrors the toggle found under Lock Screen settings so timer-specific workflows can enable or disable the widget without switching tabs.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'잠금 화면' 설정에 있는 토글과 연동되어, 탭을 전환하지 않고도 타이머 전용 워크플로에서 위젯을 활성화하거나 비활성화할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espelha a alternância encontrada nas configurações da tela de bloqueio para que os fluxos de trabalho específicos do temporizador possam ativar ou desativar o widget sem alternar as guias."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Дублирует переключатель настроек экрана блокировки для управления виджетом из этой вкладки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "镜像锁屏设置中的开关，以便计时器工作流可以无需切换标签页即可启用或禁用小组件。"
          }
        }
      }
    },
    "Monitor AI coding agents (CodeBuddy, Codex CLI, Claude Code, etc.) in the notch. Enable this and click \"Auto Configure All\" below to set up automatically.": {},
    "Monitor clipboard changes and keep a history of recent copies. Use Cmd+Shift+V to quickly access clipboard history.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클립보드 변경 사항을 모니터링하고 최근 복사 기록을 유지합니다. Cmd+Shift+V를 눌러 클립보드 기록에 빠르게 접근할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitore as alterações na área de transferência e mantenha um histórico de cópias recentes. Use Cmd+Shift+V para acessar rapidamente o histórico da área de transferência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отслеживайте изменения буфера обмена и ведите историю копирования. Нажмите Cmd+Shift+V для быстрого доступа."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监控剪贴板变化并保留最近复制的历史记录。使用 Cmd+Shift+V 快速访问剪贴板历史。"
          }
        }
      }
    },
    "Monitor your Downloads folder for Chromium-style downloads (.crdownload files) and show a live activity in the Dynamic Island while downloads are in progress.": {
      "comment": "A footer description for the \"Downloads\" section of the settings view.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드 폴더에서 크로미움 스타일의 다운로드(.crdownload 파일)를 감지하고, 다운로드가 진행되는 동안 Dynamic Island에 실시간 현황을 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Monitore sua pasta Downloads para downloads no estilo Chromium (arquivos .crdownload) e mostre uma atividade ao vivo na Dynamic Island enquanto os downloads estão em andamento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отслеживает папку загрузок на наличие файлов Chromium (.crdownload) и показывает процесс в Dynamic Island."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监控下载文件夹中 Chromium 风格的下载（.crdownload 文件），并在下载进行时在灵动岛中显示实时活动。"
          }
        }
      }
    },

    "Collect the latest crash report to share with the developer when reporting lock screen or overlay issues.": {
      "comment": "A footer for the \"Diagnostics\" section of the lock screen settings.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠금 화면 또는 오버레이 문제를 보고할 때 개발자에게 공유할 최신 충돌 보고서를 수집합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Colete o relatório de falhas mais recente para compartilhar com o desenvolvedor ao relatar problemas de tela de bloqueio ou sobreposição."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разработка и отладка: цветовая пипетка, мониторинг статистики и экранный помощник."
          }
        },
        "zh-Hans": {

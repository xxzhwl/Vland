    "Turn this off to include all-day entries in the notch calendar and reminder live activity.": {
      "comment": "A description of why the user can disable the \"Hide all-day events\" toggle.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노치 캘린더 및 미리 알림 실시간 현황에 종일 일정을 포함하려면 이 기능을 끄세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desative para incluir entradas de dia inteiro no calendário do notch e lembrete de atividades ao vivo."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выключите, чтобы включить события на весь день."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭此项以在刘海日历和提醒实时活动中包含全天事件。"
          }
        }
      }
    },
    "Two-finger swipe up on notch to close, two-finger swipe down on notch to open when **Open notch on hover** option is disabled": {
      "comment": "A footer text explaining the gesture control functionality.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Two-finger swipe up on notch to close, two-finger swipe down on notch to open when **Open notch on hover** option is disabled"
          }
        },
        "cs": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Two-finger swipe up on notch to close, two-finger swipe down on notch to open when **Open notch on hover** option is disabled"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwei-Finger Wischen nach oben zum Schließen der Notch, zwei-Finger wischen nach unten um die Notch zu öffnen, wenn die Option **Notch bei Mausberührung öffnen** deaktiviert ist"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",

          "stringUnit": {
            "state": "translated",
            "value": "팝오버 모드는 클립보드 버튼에 연결된 드롭다운 형식으로 클립보드를 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo popover mostra a área de transferência como um menu suspenso anexado ao botão da área de transferência."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Всплывающее окно"
          }
        }
      }
    },
    "Popover mode shows color picker as a dropdown attached to the color picker button. Panel mode shows color picker in a floating window.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팝오버 모드는 색상 선택기 버튼에 연결된 드롭다운 형식으로 색상 선택기를 표시합니다. 패널 모드는 플로팅 윈도우에 색상 선택기를 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo popover mostra o seletor de cores como um menu suspenso anexado ao botão do seletor de cores. O modo painel mostra o seletor de cores em uma janela flutuante."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Поведение отображения пипетки."
          }
        }
      }
    },
    "Popover mode shows the assistant as a dropdown attached to the AI button. Panel mode shows the assistant in a floating window near the notch.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "팝오버 모드는 AI 버튼에 연결된 드롭다운 형식으로 어시스턴트를 표시합니다. 패널 모드는 노치 근처의 플로팅 윈도우에 어시스턴트를 표시합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo Popover mostra o assistente como um menu suspenso conectado ao botão AI. O modo painel mostra o assistente em uma janela flutuante perto do notch."
          }
        },
        "ru": {

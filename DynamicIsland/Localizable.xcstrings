    "Color-coded fills and smooth gradients are unavailable in Segmented mode. Switch to Hierarchical or Gradient to adjust these options.": {
      "comment": "An explanatory text that appears when the user tries to enable color-coded color gradients in Segmented progress bars. It instructs the user to switch to Hierarchical or Gradient progress bars to enable these features.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'세그먼트' 모드에서는 색상별 채우기 및 부드러운 그라데이션을 사용할 수 없습니다. 이 옵션을 조정하려면 '계층형' 또는 '그라데이션'으로 전환하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Enchimentos codificados por cores e gradientes suaves não estão disponíveis no modo Segmentado. Mude para Hierárquico ou Gradiente para ajustar essas opções."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цветная заливка и градиенты недоступны в режиме Segmented."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分段模式下不支持彩色填充和平滑渐变。切换到层级或渐变模式来调整这些选项。"
          }
        }
      }
    },
    "Color-coded fills are unavailable in Segmented mode. Switch to Hierarchical or Gradient inside Controls › Dynamic Island to adjust advanced options.": {
      "comment": "A message explaining that color-coded battery indicators are unavailable in segmented progress bar style. It also includes a suggestion to switch to a more advanced progress bar style to adjust advanced options.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'세그먼트' 모드에서는 색상별 채우기를 사용할 수 없습니다. 고급 옵션을 조정하려면 '제어기 › Dynamic Island'에서 '계층형' 또는 '그라데이션'으로 전환하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Os preenchimentos codificados por cores não estão disponíveis no modo Segmentado. Mude para Hierárquico ou Gradiente em Controles ›Dynamic Island para ajustar opções avançadas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Цветная заливка недоступна в режиме Segmented."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分段模式下不支持彩色填充。切换到控制 › 灵动岛中的层级或渐变模式来调整高级选项。"
          }
        }
      }
    },

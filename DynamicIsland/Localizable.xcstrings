          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "'색상 기록 지우기'를 선택하면 추출한 모든 색상이 삭제됩니다. '색상 선택 시작'을 선택하면 화면 색상 캡처 모드가 시작됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Limpar histórico de cores remove todas as cores escolhidas. Iniciar a seleção de cores inicia o modo de captura de cores da tela."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Очистка удаляет все цвета. Запуск выбора включает режим захвата цвета."
          }
        },
        "zh-Hans": {
          "stringUnit": {

    "Smooth transitions blend Green (0–60%), Yellow (60–85%), and Red (85–100%) through the entire fill.": {
      "comment": "A description of how the color-coding feature works.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체 채우기 영역에서 초록색(0~60%), 노란색(60~85%), 빨간색(85~100%)이 부드럽게 혼합되어 표시됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Transições suaves misturam Verde (0–60%), Amarelo (60–85%) e Vermelho (85–100%) em todo o preenchimento."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плавный переход от зеленого (0-60%) к желтому (60-85%) и красному (85-100%)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "平滑过渡在整个填充中混合绿色（0-60%）、黄色（60-85%）和红色（85-100%）。"
          }
        }
      }
    },
    "Smooth transitions blend Green (0–60%), Yellow (60–85%), and Red (85–100%) through the entire fill. Adjust gradient behavior from Controls › Dynamic Island.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체 채우기 영역에서 초록색(0~60%), 노란색(60~85%), 빨간색(85~100%)이 부드럽게 혼합되어 표시됩니다. '제어기 › Dynamic Island'에서 그라데이션 동작을 조정할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Transições suaves misturam Verde (0–60%), Amarelo (60–85%) e Vermelho (85–100%) em todo o preenchimento. Ajuste o comportamento do gradiente em Controles › Dynamic Island."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Плавный переход от зеленого (0-60%) к желтому (60-85%) и красному (85-100%)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

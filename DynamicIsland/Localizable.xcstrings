          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите звуковой файл для окончания таймера. Поддерживаются форматы: MP3, M4A, WAV, AIFF."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",

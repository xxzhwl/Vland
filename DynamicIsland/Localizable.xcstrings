          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Scorri due dita verso l'alto sulla notch per chiudere, scorri due dita verso il basso sulla tacca per aprirla quando l'opzione **Apri notch all'hover ** è disabilitata"
          }

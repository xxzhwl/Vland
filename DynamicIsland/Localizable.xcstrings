        }
      }
    },
    "Applies the notch-style parallax effect to the lock screen media widget album art.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "잠금 화면 미디어 위젯의 앨범 아트에 노치 스타일의 패럴랙스 효과를 적용합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplica o efeito de paralaxe ao notch à arte do álbum do widget de mídia da tela de bloqueio."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Music"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将刘海风格的视差效果应用于锁屏媒体小组件的专辑封面。"
          }
        }
      }
    },
    "Apps using VlandExtensionKit will appear here once they request permission": {
      "comment": "A description below the placeholder text in the \"Search extensions...\" text field, explaining that apps using VlandExtensionKit will be listed here once they grant permission to use the app.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "VlandExtensionKit을 사용하는 앱이 권한을 요청하면 여기에 표시됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplicativos usando VlandExtensionKit aparecerão aqui assim que solicitarem permissão"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложения с VlandExtensionKit появятся здесь после запроса разрешения."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 VlandExtensionKit 的应用在请求权限后将显示在此处"
          }
        }
      }
    },
    "Are you sure you want to delete \"%@\"?": {
      "comment": "A confirmation prompt asking the user to confirm the deletion of a custom idle animation. The placeholder text inside the quotation marks should be replaced with the name of the animation.",
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer \"%@\" ?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "\"%@\"을(를) 삭제하시겠습니까?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir “%@”?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "AQI"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要删除「%@」吗？"
          }
        }
      }
    },
    "Are you sure you want to delete this color from your history?": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Voulez-vous vraiment supprimer cette couleur de votre historique ?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 색상을 기록에서 삭제하시겠습니까?"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Tem certeza de que deseja excluir essa cor do seu histórico?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удалить этот цвет из истории?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您确定要从历史记录中删除此颜色吗？"
          }
        }
      }
    },
    "Ask me anything...": {
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Demandez-moi ce que vous voulez…"
          }
        },
        "ko": {

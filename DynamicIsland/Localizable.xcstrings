    "Control timer availability, live activity behaviour, and whether the app mirrors timers started from the macOS Clock app.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "타이머 활성화 여부, 실시간 현황 동작, 그리고 macOS '시계' 앱에서 시작된 타이머의 연동 여부를 제어합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Controle a disponibilidade do cronômetro, o comportamento da atividade ao vivo e se o aplicativo espelha os temporizadores iniciados no aplicativo Relógio do MacOS."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Управляет доступностью таймера, Live Activities и тем, дублирует ли приложение таймеры из системного приложения Часы."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "控制计时器可用性、实时活动行为，以及应用是否同步 macOS 时钟应用启动的计时器。"
          }
        }
      }
    },
    "Controls": {

          }
        }
      }
    },
    "Opens a transparent preview window with mock data that mirrors the current lock screen widget configuration.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 잠금 화면 위젯 설정이 반영된 가상 데이터와 함께 투명한 미리보기 창을 엽니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открывает прозрачное окно предпросмотра, которое дублирует конфигурацию виджетов."
          }
        }
      }
    },
    "Opens the AI assistant panel for file analysis and conversation. Default is Cmd+Shift+A. Only works when screen assistant feature is enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "파일 분석 및 대화를 위한 AI 어시스턴트 패널을 엽니다. 기본 단축키는 Cmd+Shift+A이며, 화면 어시스턴트 기능이 활성화된 경우에만 작동합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre o painel do assistente de IA para análise e conversação de arquivos. O padrão é Cmd+Shift+A. Só funciona quando o recurso de assistente de tela está ativado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открывает прозрачное окно предварительного просмотра с имитаций данных, отражающих текущую конфигурацию виджета экрана блокировки."
          }
        }
      }
    },
    "Opens the clipboard history panel. Default is Cmd+Shift+V (similar to Windows+V on PC). Only works when clipboard feature is enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "클립보드 기록 패널을 엽니다. 기본 단축키는 Cmd+Shift+V(Windows의 Win+V와 유사)이며,"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre o painel de histórico da área de transferência. O padrão é Cmd+Shift+V (semelhante ao Windows+V no PC). Só funciona quando o recurso da área de transferência está ativado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открывает панель буфера обмена. По умолчанию Cmd+Shift+V."
          }
        }
      }
    },
    "Opens the color picker panel for screen color capture. Default is Cmd+Shift+P. Only works when color picker feature is enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "화면 색상 캡처를 위한 색상 선택기 패널을 엽니다. 기본 단축키는 Cmd+Shift+P이며, 색상 선택기 기능이 활성화된 경우에만 작동합니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Abre o painel do seletor de cores para captura de cores da tela. O padrão é Cmd+Shift+P. Só funciona quando o recurso de seleção de cores está ativado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открывает панель пипетки цветов. По умолчанию Cmd+Shift+P."
          }
        }
      }
    },
    "Opens the terminal tab in the notch. Default is Ctrl+`. Only works when terminal feature is enabled.": {
      "localizations": {
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "노치에서 터미널 탭을 엽니다. 기본 단축키는 Ctrl+`이며, 터미널 기능이 활성화된 경우에만 작동합니다."
          }
        },
        "ru": {
          "stringUnit": {

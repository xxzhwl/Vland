        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "타이머가 종료될 때 재생할 사용자 지정 사운드 파일을 선택하세요. 지원 형식: MP3, M4A, WAV, AIFF."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
